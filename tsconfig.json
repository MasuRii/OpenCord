{
    "compilerOptions": {
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": false,
        "allowJs": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "esnext",
            "esnext.array",
            "esnext.asynciterable",
            "esnext.symbol"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": false,
        "target": "ESNEXT",
        "jsx": "preserve",
        "paths": {
            "@main/*": [
                "./src/main/*"
            ],
            "@api/*": [
                "./src/api/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@debug/*": [
                "./src/debug/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@plugins/*": [
                "./src/plugins/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@webpack/common": [
                "./src/webpack/common"
            ],
            "@webpack/common/*": [
                "./src/webpack/common/*"
            ],
            "@webpack": [
                "./src/webpack/webpack"
            ],
            "@webpack/patcher": [
                "./src/webpack/patchWebpack"
            ],
            "@webpack/wreq.d": [
                "./src/webpack/wreq.d"
            ],
            "@webpack/types": [
                "./src/webpack/types"
            ],
            "@equicordplugins/*": [
                "./src/equicordplugins/*"
            ],
            "@opencordplugins/*": [
                "./src/opencordplugins/*"
            ],
            "@illegalcordplugins/*": [
                "./src/illegalcordplugins/*"
            ],
            "@testcordplugins/*": [
                "./src/testcordplugins/*"
            ],
            "@esharqplugins/*": [
                "./src/esharqplugins/*"
            ],
            "@equicordplusplugins/*": [
                "./src/equicordplusplugins/*"
            ],
            "@mallcordplugins/*": [
                "./src/mallcordplugins/*"
            ],
            // Cross-collection aliases: upstream plugins use these paths which
            // differ from OpenCord's collection-scoped layout. Map them so
            // synced upstream code compiles without manual import rewrites.
            "@utils/esharqI18n": [
                "./src/esharqplugins/_esharqI18n"
            ],
            "@utils/apiKeyWarning": [
                "./src/testcordplugins/_shared/apiKeyWarning"
            ],
            "@utils/cacheLimits": [
                "./src/testcordplugins/_shared/cacheLimits"
            ],
            "@plugins/philsPluginLibrary": [
                "./src/esharqplugins/philsPluginLibrary"
            ],
            "@plugins/philsPluginLibrary/*": [
                "./src/esharqplugins/philsPluginLibrary/*"
            ],
            "@plugins/fakeDeafen": [
                "./src/esharqplugins/fakeDeafen"
            ],
            "@plugins/betterMicrophone.desktop": [
                "./src/esharqplugins/betterMicrophone.desktop"
            ],
            "@plugins/betterMicrophone.desktop/*": [
                "./src/esharqplugins/betterMicrophone.desktop/*"
            ],
            "discord-types/general": [
                "./packages/discord-types/src/index"
            ]
        },
        "plugins": [
            // Transform paths in output .d.ts files (Include this line if you output declarations files)
            {
                "transform": "typescript-transform-paths",
                "afterDeclarations": true
            }
        ],
        "outDir": "who-fucking-cares-dude"
    },
    "include": [
        "src/**/*",
        "browser/**/*",
        "scripts/**/*",
        "eslint.config.mjs"
    ],
}